    "@vercel/analytics": "^2.0.1",
    "antd": "^6.3.3",
    "dexie": "^4.3.0",
    "framer-motion": "^12.35.2",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "jszip": "^3.10.1",
    "pdfjs-dist": "5.4.149",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
